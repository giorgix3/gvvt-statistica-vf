# Copy this file to .env and fill in real values.
# .env is listed in .gitignore and must never be committed.

# Vereinsflieger application key (issued per third-party app)
VF_APP_KEY=your_app_key_here

# Vereinsflieger club ID
VF_CLUB_ID=0

# FTP deployment target (used by GitHub Actions only — set these as repo secrets)
# FTP_HOST=ftp.yourhostingprovider.com
# FTP_USER=your_ftp_username
# FTP_PASSWORD=your_ftp_password
# FTP_PATH=/public_html/statistica/
